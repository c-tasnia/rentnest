# Server
PORT=5000
NODE_ENV=development

# Database (Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/rentnest?schema=public"

# JWT
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Admin seed credentials (used by prisma/seed.ts)
ADMIN_EMAIL="admin@rentnest.com"
ADMIN_PASSWORD="admin123"

# SSLCommerz
SSLCZ_STORE_ID="your_store_id"
SSLCZ_STORE_PASSWORD="your_store_password"
SSLCZ_IS_LIVE=false

# Public URLs (used for SSLCommerz redirect callbacks)
BACKEND_URL="http://localhost:5000"
FRONTEND_URL="http://localhost:3000"
