generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum PropertyStatus {
  AVAILABLE
  UNAVAILABLE
  RENTED
}

enum RentalStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
}

enum PaymentProvider {
  STRIPE
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  phone     String?
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  properties     Property[]      @relation("LandlordProperties")
  rentalRequests RentalRequest[] @relation("TenantRentals")
  reviews        Review[]        @relation("TenantReviews")
  payments       Payment[]       @relation("TenantPayments")

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  properties Property[]

  @@map("categories")
}

model Property {
  id          String         @id @default(uuid())
  title       String
  description String
  address     String
  city        String
  price       Decimal        @db.Decimal(10, 2)
  bedrooms    Int            @default(1)
  bathrooms   Int            @default(1)
  amenities   String[]       @default([])
  images      String[]       @default([])
  status      PropertyStatus @default(AVAILABLE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  landlordId String
  landlord   User   @relation("LandlordProperties", fields: [landlordId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  rentalRequests RentalRequest[]
  reviews        Review[]

  @@index([city])
  @@index([price])
  @@map("properties")
}

model RentalRequest {
  id         String       @id @default(uuid())
  status     RentalStatus @default(PENDING)
  moveInDate DateTime
  message    String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenantId String
  tenant   User   @relation("TenantRentals", fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  payment Payment?
  review  Review?

  @@map("rental_requests")
}

model Payment {
  id            String          @id @default(uuid())
  transactionId String          @unique
  amount        Decimal         @db.Decimal(10, 2)
  method        String
  provider      PaymentProvider @default(SSLCOMMERZ)
  status        PaymentStatus   @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  rentalRequestId String        @unique
  rentalRequest   RentalRequest @relation(fields: [rentalRequestId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   User   @relation("TenantPayments", fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   User   @relation("TenantReviews", fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  rentalRequestId String        @unique
  rentalRequest   RentalRequest @relation(fields: [rentalRequestId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
